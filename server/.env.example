# Copy this file to .env and fill in real values. Never commit the real .env.

# --- Core ---
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# --- Admin auth ---
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-value

# --- Storage ---
# Local dev default is SQLite (no setup needed). For production, point this
# at a mounted volume path, or migrate to Supabase Postgres using
# server/sql/schema.sql and swap the driver in src/db.js.
SQLITE_PATH=./data/drugphobia.db

# --- Guarded LLM layer (optional) ---
# If LLM_API_KEY is left blank, the server runs entirely on the offline
# fallback in src/aiClient.js — the product is fully demoable with zero
# external API keys. Fill these in to enable live conversational answers.
LLM_API_KEY=
LLM_API_URL=https://api.example-llm-provider.com/v1/chat/completions
LLM_MODEL=llama-3-8b-instruct
