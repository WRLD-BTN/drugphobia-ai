# Used by docker-compose.yml. Copy to .env in the repo root before running
# `docker compose up`. Per-service .env.example files (server/, client/,
# admin/) are for running each piece outside Docker during development.

JWT_SECRET=replace-with-a-long-random-value
LLM_API_KEY=
LLM_API_URL=
LLM_MODEL=llama-3-8b-instruct

# The public URL the browser will use to reach the server — matters for
# docker-compose builds since Vite bakes this in at build time.
PUBLIC_SERVER_URL=http://localhost:4000
